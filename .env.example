# SMTP OVH — envoi des emails du formulaire de contact vers le Webmail du client
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Adresse email de réception des demandes de devis (boîte mail du client)
CONTACT_EMAIL=

# URL de production du site (sans slash final), utilisée pour générer les
# URLs absolues de sitemap.xml et robots.txt. Exemple : https://votre-domaine.fr
NEXT_PUBLIC_SITE_URL=
