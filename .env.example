# Resend (https://resend.com) — envoi des emails du formulaire de contact
RESEND_API_KEY=

# Adresse email de réception des demandes de devis (boîte mail du client)
CONTACT_TO_EMAIL=

# Adresse d'expédition des emails. En production, utilisez un domaine
# vérifié dans Resend pour une meilleure délivrabilité.
# Par défaut si non renseigné : "Artisans Michelet <onboarding@resend.dev>"
CONTACT_FROM_EMAIL=

# URL de production du site (sans slash final), utilisée pour générer les
# URLs absolues de sitemap.xml et robots.txt. Exemple : https://votre-domaine.fr
NEXT_PUBLIC_SITE_URL=
